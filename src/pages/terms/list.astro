---
import { Button, CardList } from 'astro-pure/user'
import { cn } from 'astro-pure/utils'
import PageLayout from '@/layouts/BaseLayout.astro'
import { integ, terms } from '@/site-config'
import { t } from '@/i18n'

const meta = {
  title: t('terms.title'),
  description: 'Documentation des politiques du site'
}
---

<PageLayout {meta}>
  <Button title={t('nav.back')} href='/' variant='back' />
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-6 text-3xl font-medium'>{t('terms.title')}</h1>
    </div>

    <div id='content' class={cn('animate mt-8 max-w-none md:min-w-[45ch]', integ.typography.class)}>
      <h2 class='text-xl font-medium'>Documentation des politiques du site</h2>
      <CardList {...terms} />
    </div>
  </main>
</PageLayout>
